{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "lib": ["es2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"] // <-- Esto le enseña a TypeScript qué es 'console' y 'process'
  },
  "include": ["prisma/**/*", "src/**/*"]
}