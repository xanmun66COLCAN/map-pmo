// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. ENUMS
enum EstadoProyecto {
  Planificacion @map("Planificación")
  En_Ejecucion  @map("En Ejecución")
  Pausado
  Completado
}

enum FrecuenciaMedicion {
  Semanal
  Mensual
  Trimestral
}

// 2. MODELO: USUARIOS (Optimizado)
model Usuario {
  id           Int                 @id @default(autoincrement())
  email        String              @unique
  password     String
  nombre       String              @db.VarChar(100) // <-- Agregado
  apellido     String              @db.VarChar(100) // <-- Agregado
  created_at   DateTime            @default(now())
  
  asignaciones   AsignacionRecurso[]
  historial_kpis HistorialKpi[]      // <-- Agregado para la relación inversa de auditoría

  @@map("usuarios") // <-- Agregado para mantener consistencia en la BD
}

// 3. MODELO: PROYECTOS
model Proyecto {
  id           Int                 @id @default(autoincrement())
  nombre       String              @db.VarChar(150)
  descripcion  String?             @db.Text
  fecha_inicio DateTime            @db.Date
  fecha_fin    DateTime?           @db.Date
  estado       EstadoProyecto      @default(Planificacion)
  presupuesto  Decimal             @default(0.00) @db.Decimal(12, 2)
  created_at   DateTime            @default(now())
  updated_at   DateTime            @updatedAt

  kpis         Kpi[]
  asignaciones AsignacionRecurso[]

  @@map("proyectos")
}

// 4. MODELO: ASIGNACIÓN DE RECURSOS
model AsignacionRecurso {
  id                    Int       @id @default(autoincrement())
  proyecto_id           Int
  usuario_id            Int
  porcentaje_asignacion Int
  fecha_desde           DateTime  @db.Date
  fecha_hasta           DateTime? @db.Date
  created_at            DateTime  @default(now())

  proyecto              Proyecto  @relation(fields: [proyecto_id], references: [id], onDelete: Cascade)
  usuario               Usuario   @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@map("asignacion_recursos")
}

// 5. MODELO: KPIS
model Kpi {
  id            Int                @id @default(autoincrement())
  proyecto_id   Int
  nombre_kpi    String             @db.VarChar(100)
  descripcion   String?            @db.Text
  meta_valor    Decimal            @db.Decimal(10, 2)
  valor_actual  Decimal            @default(0.00) @db.Decimal(10, 2)
  frecuencia    FrecuenciaMedicion @default(Mensual)
  unidad_medida String             @db.VarChar(20)
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt

  proyecto      Proyecto           @relation(fields: [proyecto_id], references: [id], onDelete: Cascade)
  historial     HistorialKpi[]

  @@map("kpis")
}

// 6. MODELO: HISTORIAL DE KPIS (Con relación completa)
model HistorialKpi {
  id               Int      @id @default(autoincrement())
  kpi_id           Int
  valor_registrado Decimal  @db.Decimal(10, 2)
  fecha_registro   DateTime @default(now())
  usuario_id       Int?     // ¿Quién actualizó la métrica?

  kpi              Kpi      @relation(fields: [kpi_id], references: [id], onDelete: Cascade)
  usuario          Usuario? @relation(fields: [usuario_id], references: [id], onDelete: SetNull) // <-- Relación agregada

  @@map("historial_kpis")
}