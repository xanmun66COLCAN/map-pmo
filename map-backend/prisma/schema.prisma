generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id             Int                 @id @default(autoincrement())
  nombre         String              @db.VarChar(100)
  correo         String              @unique @db.VarChar(100)
  contrasena     String              @db.VarChar(255)
  id_rol         Int?
  fecha_creacion DateTime?           @default(now()) @db.Timestamp(6)
  logs_auditoria logs_auditoria[]
  roles          roles?              @relation(fields: [id_rol], references: [id], onDelete: Restrict, onUpdate: NoAction)
  asignaciones   AsignacionRecurso[] // 👈 Relación agregada para rastrear en qué proyectos trabaja el usuario

  @@map("usuarios")
}

model Proyecto {
  id           Int                 @id @default(autoincrement())
  nombre       String              @db.VarChar(150)
  descripcion  String?
  fecha_inicio DateTime            @db.Date
  fecha_fin    DateTime?           @db.Date
  estado       EstadoProyecto?     @default(Idea) // 👈 Apuntando al Enum correcto
  presupuesto  Decimal?            @default(0.00) @db.Decimal(12, 2)
  created_at   DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at   DateTime?           @default(now()) @updatedAt @db.Timestamptz(6)
  asignaciones AsignacionRecurso[]
  kpis         Kpi[]

  @@map("proyectos")
}

model AsignacionRecurso {
  id                    Int       @id @default(autoincrement())
  proyecto_id           Int
  usuario_id            Int
  porcentaje_asignacion Int
  fecha_desde           DateTime  @db.Date
  fecha_hasta           DateTime? @db.Date
  created_at            DateTime? @default(now()) @db.Timestamptz(6)
  proyecto              Proyecto  @relation(fields: [proyecto_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuario               Usuario   @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction) // 👈 ¡ESTA ERA LA LÍNEA CLAVE QUE FALTABA!

  @@index([proyecto_id], map: "idx_asignaciones_proyecto")
  @@index([usuario_id], map: "idx_asignaciones_usuario")
  @@map("asignacion_recursos")
}

model Kpi {
  id            Int                  @id @default(autoincrement())
  proyecto_id   Int
  nombre_kpi    String               @db.VarChar(100)
  descripcion   String?
  meta_valor    Decimal              @db.Decimal(10, 2)
  valor_actual  Decimal?             @default(0.00) @db.Decimal(10, 2)
  frecuencia    frecuencia_medicion? @default(Mensual)
  unidad_medida String               @db.VarChar(20)
  created_at    DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?            @default(now()) @updatedAt @db.Timestamptz(6)
  historial     HistorialKpi[]
  proyecto      Proyecto             @relation(fields: [proyecto_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([proyecto_id], map: "idx_kpis_proyecto")
  @@map("kpis")
}

model HistorialKpi {
  id               Int       @id @default(autoincrement())
  kpi_id           Int
  valor_registrado Decimal   @db.Decimal(10, 2)
  fecha_registro   DateTime? @default(now()) @db.Timestamptz(6)
  usuario_id       Int?
  kpi              Kpi       @relation(fields: [kpi_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([kpi_id, fecha_registro], map: "idx_historial_kpi")
  @@map("historial_kpis")
}

model logs_auditoria {
  id                Int       @id @default(autoincrement())
  id_proyecto       Int?      // 👈 Cambiado de id_iniciativa a id_proyecto para mantener la coherencia
  id_usuario_accion Int?
  campo_modificado  String    @db.VarChar(100)
  valor_anterior    String?   @db.VarChar(255)
  valor_nuevo       String?   @db.VarChar(255)
  fecha_transaccion DateTime? @default(now()) @db.Timestamp(6)
  usuarios          Usuario?  @relation(fields: [id_usuario_accion], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model roles {
  id         Int       @id @default(autoincrement())
  nombre_rol String    @unique @db.VarChar(50)
  usuarios   Usuario[]
}

// Cambiado de 'estado_proyecto' a 'EstadoProyecto' para coincidir perfectamente
enum EstadoProyecto {
  Idea
  Evaluacion
  Caso_de_Negocio
  Aprobado
  Rechazado
}

enum frecuencia_medicion {
  Semanal
  Mensual
  Trimestral
}